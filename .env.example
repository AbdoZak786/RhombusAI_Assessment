# Copy to ".env" and fill in locally. Never commit ".env" or paste real secrets into this example file.

# Playwright base URL for UI tests.
# Rhombus serves both marketing and the authenticated product from the same host;
# which one you land on depends on session state.
BASE_URL=https://rhombusai.com

# UI login (Option A – AI Pipeline Flow)
#
# Recommended for Auth0-backed sites: capture a reusable storage state instead
# of clicking through the popup every run. See README "Capturing a storage state".
# When E2E_STORAGE_STATE points to an existing file, the UI test skips login.
E2E_STORAGE_STATE=.auth/rhombus.json
#
# Fallback: click-through login using email + password. Works for non-MFA accounts.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
# Optional: override navigation targets if your workspace routes differ
E2E_LOGIN_PATH=/
E2E_PIPELINE_PATH=/
E2E_PIPELINE_PROMPT=Clean this data and remove null rows
E2E_PIPELINE_TIMEOUT_MS=180000
# Optional: name used when the UI asks for a new project before upload is available
# E2E_PROJECT_NAME=e2e-smoke-project

# API tests (Playwright request context)
# Full URL of the app's dataset upload (multipart). NOT the analytics POST to /ph-rhombus/s/ — see README "Reading DevTools Network".
# Example (confirm in DevTools): https://api.rhombusai.com/api/dataset/datasets/temp/upload
API_DATASET_UPLOAD_URL=
# JWT or API key only (no "Bearer " prefix — Playwright adds that header).
RHOMBUS_API_TOKEN=
# Alternative name for the same value:
# API_BEARER_TOKEN=
