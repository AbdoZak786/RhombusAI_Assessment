{
  "name": "rhombus-ai-test-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright UI/API tests and Python data validation for Rhombus AI",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.7.2"
  }
}
